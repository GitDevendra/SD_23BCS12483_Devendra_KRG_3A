        <mxCell id="j3CgrBnfzvBNI35uA5K0-136" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="NOTIFICATION SVC" vertex="1">
          <mxGeometry height="60" width="280" x="870" y="1160" as="geometry" />
